# ─── Server ──────────────────────────────────────────────
PORT=3000

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Driver matching ─────────────────────────────────────
# Maximum radius (km) to search for nearby drivers
MATCH_RADIUS_KM=5

# ─── CORS ────────────────────────────────────────────────
# Origin(s) allowed to call this API from a browser.
# Comma-separate multiple origins to support both a web client and a mobile client:
#   CORS_ORIGIN=https://app.wasee.com,https://driver.wasee.com
# Use * to allow all origins during local development/testing ONLY.
# WARNING: Never use * in production – always set this to your exact frontend URL(s).
CORS_ORIGIN=http://localhost:5173

# ─── Rate limiting ───────────────────────────────────────
# Time window in milliseconds (default: 60 000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000
# Maximum requests per IP per window (default: 100)
RATE_LIMIT_MAX=100
