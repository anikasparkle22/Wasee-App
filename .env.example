# ─── Server ──────────────────────────────────────────────
PORT=3000

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Driver matching ─────────────────────────────────────
# Maximum radius (km) to search for nearby drivers
MATCH_RADIUS_KM=5

# ─── CORS ────────────────────────────────────────────────
# Origin(s) allowed to call this API from a browser.
# Use * to allow all origins during local development/testing ONLY.
# WARNING: Never use * in production – set this to your exact frontend URL(s).
# Multiple origins can be comma-separated:
#   CORS_ORIGIN=https://rider.wasee.app,https://driver.wasee.app
CORS_ORIGIN=http://localhost:5173

# ─── Rate limiting ───────────────────────────────────────
# Time window in milliseconds (default: 60 000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000
# Maximum requests per IP per window (default: 100)
RATE_LIMIT_MAX=100
